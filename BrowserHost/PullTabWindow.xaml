<Window x:Class="BrowserHost.PullTabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Width="180" Height="40"
        Focusable="False"
        ShowActivated="False">
    <Border Background="#CC1A1A1A"
            CornerRadius="0,0,10,10"
            Cursor="Hand">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.5" Direction="270"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="22" Height="22" Margin="0,0,6,0">
                <Canvas Width="24" Height="24">
                    <Rectangle Canvas.Left="2" Canvas.Top="5"  Width="20" Height="2.5" RadiusX="1" RadiusY="1" Fill="White"/>
                    <Rectangle Canvas.Left="2" Canvas.Top="11" Width="20" Height="2.5" RadiusX="1" RadiusY="1" Fill="White"/>
                    <Rectangle Canvas.Left="2" Canvas.Top="17" Width="20" Height="2.5" RadiusX="1" RadiusY="1" Fill="White"/>
                </Canvas>
            </Viewbox>
            <TextBlock Text="Menu" Foreground="White" FontFamily="Segoe UI"
                       FontSize="15" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
