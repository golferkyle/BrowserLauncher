<Window x:Class="BrowserHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Icon="BrowserLauncher.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Black"
        AllowsTransparency="True">

    <Grid x:Name="RootGrid" MouseMove="RootGrid_MouseMove">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: WebView2 container. Bottom margin is animated when touch keyboard opens. -->
        <Border x:Name="WebViewContainer" Grid.Row="0">
            <wv2:WebView2 x:Name="WebView"/>
        </Border>

        <!-- Row 1: Persistent bottom command bar -->
        <Border x:Name="BottomBar" Grid.Row="1" Height="70" Background="#1A1A1A" Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="BottomBarTranslate" Y="0"/>
            </Border.RenderTransform>
            <Grid>
                <!-- Keyboard toggle button – center, visible in Button mode -->
                <Button x:Name="KeyboardButton"
                        Click="KeyboardButton_Click"
                        Focusable="False"
                        IsTabStop="False"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#333333"
                        Foreground="White"
                        FontFamily="Segoe UI"
                        FontSize="22"
                        Width="160"
                        Height="52"
                        Padding="0,4"
                        Visibility="Collapsed">
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3"/>
                    </Button.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="34" Height="34" Margin="-2,0,6,0">
                            <!-- Keyboard icon -->
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="1" Canvas.Top="5"
                                           Width="22" Height="14" RadiusX="2" RadiusY="2"
                                           Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                <Rectangle Canvas.Left="3"  Canvas.Top="8"  Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="7"  Canvas.Top="8"  Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="11" Canvas.Top="8"  Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="15" Canvas.Top="8"  Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="19" Canvas.Top="8"  Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="3"  Canvas.Top="12" Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="7"  Canvas.Top="12" Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="9"  Canvas.Top="12" Width="6" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="17" Canvas.Top="12" Width="2" Height="2" Fill="White"/>
                                <Rectangle Canvas.Left="19" Canvas.Top="12" Width="2" Height="2" Fill="White"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="KeyboardButtonText" Text="Keyboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Exit button – bottom right, visible only when URL matches ExitUrl -->
                <Button x:Name="ExitButton"
                        Click="ExitButton_Click"
                        Focusable="False"
                        IsTabStop="False"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Background="#D32F2F"
                        Foreground="White"
                        FontFamily="Segoe UI"
                        FontSize="22"
                        Width="130"
                        Height="52"
                        Padding="0,4"
                        Visibility="Collapsed">
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3"/>
                    </Button.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="34" Height="34" Margin="-2,0,4,0">
                            <Canvas Width="24" Height="24">
                                <Path Fill="White" Data="M4,3 L13,3 L13,9 L11,9 L11,5 L6,5 L6,19 L11,19 L11,15 L13,15 L13,21 L4,21 Z" />
                                <Path Fill="White" Data="M15,12 L9,12 L9,10 L15,10 L15,7 L21,11 L15,15 Z" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Exit" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Mouse pull-down trigger tab: overlays top-center, slides down when mouse hovers top zone -->
        <Border x:Name="MousePullTab"
                Grid.Row="0" Grid.RowSpan="2"
                Width="180" Height="40"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Background="#CC1A1A1A"
                CornerRadius="0,0,10,10"
                Cursor="Hand"
                IsHitTestVisible="True"
                MouseEnter="MousePullTab_MouseEnter"
                MouseLeave="MousePullTab_MouseLeave"
                MouseLeftButtonUp="MousePullTab_Click"
                Panel.ZIndex="100">
            <Border.RenderTransform>
                <TranslateTransform x:Name="MousePullTabTranslate" Y="-40"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.5" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Three horizontal lines (hamburger / pull indicator) -->
                <Viewbox Width="22" Height="22" Margin="0,0,6,0">
                    <Canvas Width="24" Height="24">
                        <Rectangle Canvas.Left="2" Canvas.Top="5"  Width="20" Height="2.5" RadiusX="1" RadiusY="1" Fill="White"/>
                        <Rectangle Canvas.Left="2" Canvas.Top="11" Width="20" Height="2.5" RadiusX="1" RadiusY="1" Fill="White"/>
                        <Rectangle Canvas.Left="2" Canvas.Top="17" Width="20" Height="2.5" RadiusX="1" RadiusY="1" Fill="White"/>
                    </Canvas>
                </Viewbox>
                <TextBlock Text="Menu" Foreground="White" FontFamily="Segoe UI"
                           FontSize="15" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
