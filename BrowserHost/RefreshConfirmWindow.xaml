<Window x:Class="BrowserHost.RefreshConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refresh page?" Height="200" Width="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#757575" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Refresh the current page?" FontSize="18" FontWeight="Bold" />
        <TextBlock Grid.Row="1" Text="Choose 'Refresh' to reload, 'Cancel' to dismiss, or 'Home' to navigate to the initial page." TextWrapping="Wrap" Margin="0,8,0,8" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">

            <!-- Refresh -->
            <Button x:Name="BtnRefresh" Style="{StaticResource DialogButtonStyle}" Click="BtnRefresh_Click"
                    Width="110" Height="38" Margin="0,0,10,0" Background="#1976D2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20" Margin="0,0,6,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.83,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Cancel -->
            <Button x:Name="BtnCancel" Style="{StaticResource DialogButtonStyle}" Click="BtnCancel_Click"
                    Width="110" Height="38" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20" Margin="0,0,6,0">
                        <Canvas Width="24" Height="24">
                            <Line X1="4" Y1="4" X2="20" Y2="20" Stroke="White" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line X1="20" Y1="4" X2="4" Y2="20" Stroke="White" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Home -->
            <Button x:Name="BtnHome" Style="{StaticResource DialogButtonStyle}" Click="BtnHome_Click"
                    Width="110" Height="38" Margin="0,0,10,0" Background="#388E3C">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20" Margin="0,0,6,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" Data="M10,20 L10,14 L14,14 L14,20 L19,20 L19,11 L22,11 L12,2 L2,11 L5,11 L5,20 Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Home" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Exit (same red + icon as main window Exit button) -->
            <Button x:Name="BtnExit" Style="{StaticResource DialogButtonStyle}" Click="BtnExit_Click"
                    Width="110" Height="38" Background="#D32F2F" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20" Margin="0,0,6,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" Data="M4,3 L13,3 L13,9 L11,9 L11,5 L6,5 L6,19 L11,19 L11,15 L13,15 L13,21 L4,21 Z" />
                            <Path Fill="White" Data="M15,12 L9,12 L9,10 L15,10 L15,7 L21,11 L15,15 Z" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Exit" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</Window>
